  "pages": [
    {
      "name": "e89a86b8",
      "displayName": "ultima Medicion",
      "layout": [
        {
          "widget": {
            "name": "header_current",
            "multilineTextboxSpec": {
              "lines": [
                "## 🌤️ Clima Actual"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 7,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "temperature",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "077fc02d",
                  "fields": [
                    {
                      "name": "temperature_2m",
                      "expression": "`temperature_2m`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Temperatura Actual",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "temperature_2m",
                  "format": {
                    "type": "number-plain",
                    "abbreviation": "none",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 1
                    }
                  }
                }
              },
              "data": {
                "queryName": "main_query"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "rain_counter",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "a8096cb3",
                  "fields": [
                    {
                      "name": "avg(precipitation)",
                      "expression": "AVG(`precipitation`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Lluvia Actual",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "avg(precipitation)",
                  "format": {
                    "type": "number-plain",
                    "abbreviation": "none",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 2
                    }
                  },
                  "formatTemplate": "{{ @formatted }} mm"
                }
              },
              "data": {
                "queryName": "main_query"
              }
            }
          },
          "position": {
            "x": 3,
            "y": 1,
            "width": 3,
            "height": 3
          }
        },
